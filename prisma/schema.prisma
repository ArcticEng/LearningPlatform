generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  tagline     String   @default("")
  logoUrl     String   @default("")

  // Branding
  colorPrimary    String @default("#1A2E6B")
  colorSecondary  String @default("#2A4AA8")
  colorAccent     String @default("#C3E234")
  fontHeading     String @default("Montserrat")
  fontBody        String @default("Nunito")
  colorBgDark     String @default("")

  // Feature flags (superadmin toggles per tenant)
  featureVideos       Boolean @default(false)  // video embedding in modules
  featureWhatsapp     Boolean @default(false)  // WhatsApp contact button
  whatsappNumber      String  @default("")     // e.g. "27791234567"
  featureCourseAccess Boolean @default(false)  // restrict courses per student
  featureContinue     Boolean @default(false)  // "continue where you left off"
  featureCertificates Boolean @default(false)  // auto-generate completion certificates
  featureAiImport     Boolean @default(true)   // AI test import from docs

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  courses        Course[]
  courseAccess    CourseAccess[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  idNumber  String
  password  String
  role      String   @default("learner")
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  results   Result[]
  courseAccess CourseAccess[]
  progress    Progress[]

  @@unique([idNumber, tenantId])
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String   @default("")
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  modules     Module[]
  results     Result[]
  courseAccess CourseAccess[]
}

// Per-student course access (when featureCourseAccess is enabled)
model CourseAccess {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId   String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Module {
  id        String   @id @default(uuid())
  title     String
  order     Int      @default(0)
  pdfPath   String?
  pdfName   String?
  videoUrl  String?  // YouTube/Vimeo embed URL
  courseId   String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  test      Test?
  results   Result[]
  progress  Progress[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Track student progress per module (for "continue where you left off")
model Progress {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completed  Boolean  @default(false)
  lastAccess DateTime @default(now())

  @@unique([userId, moduleId])
}

model Test {
  id        String     @id @default(uuid())
  moduleId  String     @unique
  module    Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions Question[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Question {
  id      String @id @default(uuid())
  text    String
  optionA String
  optionB String
  optionC String
  optionD String
  correct Int    @default(0)
  order   Int    @default(0)
  testId  String
  test    Test   @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model Result {
  id          String   @id @default(uuid())
  score       Int
  total       Int
  percentage  Int
  answers     String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())
}

model ErrorLog {
  id        String   @id @default(uuid())
  level     String   @default("error")
  source    String   @default("")
  path      String   @default("")
  message   String
  details   String   @default("")
  tenantId  String?
  userId    String?
  createdAt DateTime @default(now())
}
