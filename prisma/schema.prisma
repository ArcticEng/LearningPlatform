generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  tagline     String   @default("")
  logoUrl     String   @default("")

  // Branding
  colorPrimary    String @default("#1A2E6B")
  colorSecondary  String @default("#2A4AA8")
  colorAccent     String @default("#C3E234")
  fontHeading     String @default("Montserrat")
  fontBody        String @default("Nunito")
  colorBgDark     String @default("")

  // Feature flags (superadmin toggles per tenant)
  featureVideos       Boolean @default(false)  // video embedding in modules
  featureWhatsapp     Boolean @default(false)  // WhatsApp contact button
  whatsappNumber      String  @default("")     // e.g. "27791234567"
  featureCourseAccess Boolean @default(false)  // restrict courses per student
  featureContinue     Boolean @default(false)  // "continue where you left off"
  featureCertificates Boolean @default(false)  // auto-generate completion certificates
  featureAiImport     Boolean @default(true)   // AI test import from docs
  featureSelfRegister Boolean @default(false)  // learner self-registration with access codes
  featurePayments    Boolean @default(false)  // Paystack payment for course access
  featureBookings    Boolean @default(false)  // booking calendar for in-person training
  featureCourseCap   Boolean @default(false)  // limit enrollment per course
  featureWorkbooks   Boolean @default(false)  // practical skills workbooks (ACT)
  featureScheduling  Boolean @default(false)  // admin-driven training session scheduling (ACT)
  bookingAdminEmail  String  @default("")     // email to receive booking notifications
  termsUrl           String  @default("")     // URL to terms & conditions page
  forceLightMode     Boolean @default(false)   // hide dark mode toggle, always light
  paystackSubaccount String  @default("")     // Paystack subaccount code (ACCT_xxx)
  platformFeePercent Int     @default(10)      // % Onyx Digital takes per transaction

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  courses        Course[]
  courseAccess    CourseAccess[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  idNumber  String
  email     String   @default("")
  phone     String   @default("")
  password  String
  role      String   @default("learner")
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  results   Result[]
  courseAccess CourseAccess[]
  progress    Progress[]

  @@unique([idNumber, tenantId])
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String   @default("")
  imageUrl    String   @default("")          // course cover image path
  promoLabel  String   @default("")          // e.g. "Early bird price! Price increases soon!"
  price       Int      @default(0)          // price in cents (e.g. 50000 = R500.00), 0 = free
  currency    String   @default("ZAR")
  maxEnrollment Int    @default(0)           // 0 = unlimited, >0 = cap
  enrolledCount Int    @default(0)           // current enrollment count
  isBundle      Boolean @default(false)      // true = this is a bundle of other courses
  bundleCourseIds String @default("")        // comma-separated course IDs included in bundle
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  modules     Module[]
  results     Result[]
  courseAccess CourseAccess[]
}

// Per-student course access (when featureCourseAccess is enabled)
model CourseAccess {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId   String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model Module {
  id        String   @id @default(uuid())
  title     String
  order     Int      @default(0)
  pdfPath   String?
  pdfName   String?
  videoUrl  String?  // YouTube/Vimeo embed URL
  courseId   String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  test      Test?
  results   Result[]
  progress  Progress[]
  workbook  Workbook?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Track student progress per module (for "continue where you left off")
model Progress {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completed  Boolean  @default(false)
  lastAccess DateTime @default(now())

  @@unique([userId, moduleId])
}

model Test {
  id        String     @id @default(uuid())
  moduleId  String     @unique
  module    Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions Question[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Question {
  id      String @id @default(uuid())
  text    String
  optionA String
  optionB String
  optionC String
  optionD String
  correct Int    @default(0)
  order   Int    @default(0)
  testId  String
  test    Test   @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model Result {
  id          String   @id @default(uuid())
  score       Int
  total       Int
  percentage  Int
  answers     String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())
}

model ErrorLog {
  id        String   @id @default(uuid())
  level     String   @default("error")
  source    String   @default("")
  path      String   @default("")
  message   String
  details   String   @default("")
  tenantId  String?
  userId    String?
  createdAt DateTime @default(now())
}

model AccessCode {
  id        String    @id @default(uuid())
  code      String                        // e.g. "SRB-NAILS-2026"
  tenantId  String
  courseId  String?                        // auto-assign this course on registration
  maxUses   Int       @default(0)          // 0 = unlimited
  usedCount Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@unique([code, tenantId])
}

model Payment {
  id              String   @id @default(uuid())
  tenantId        String
  userId          String?              // null until registration completes
  courseId        String
  email           String
  name            String   @default("")
  idNumber        String   @default("")
  phone           String   @default("")
  address         String   @default("")   // delivery address
  amount          Int                  // in cents
  currency        String   @default("ZAR")
  status          String   @default("pending") // pending | success | failed
  paystackRef     String   @unique      // Paystack reference
  paystackAccess  String   @default("") // Paystack access_code for checkout
  accessCode      String   @default("") // our access code (if used alongside)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BookingSlot {
  id          String    @id @default(uuid())
  tenantId    String
  courseId    String?                          // optional: tie slot to specific course
  title       String    @default("")           // e.g. "Gel Nails Practical - Morning"
  date        DateTime                         // the date of the session
  startTime   String    @default("")           // e.g. "09:00"
  endTime     String    @default("")           // e.g. "12:00"
  location    String    @default("")           // e.g. "Studio A, Cape Town"
  capacity    Int       @default(10)           // max students
  bookedCount Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  bookings    Booking[]
}

model Booking {
  id            String      @id @default(uuid())
  tenantId      String
  slotId        String
  slot          BookingSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  courseId      String?
  studentName   String
  studentEmail  String
  studentPhone  String      @default("")
  studentId     String      @default("")       // ID number
  userId        String?                         // if registered user
  paymentId     String?                         // if linked to a payment
  status        String      @default("confirmed") // confirmed | cancelled
  notes         String      @default("")
  createdAt     DateTime    @default(now())

  @@unique([slotId, studentEmail])
}

model Workbook {
  id          String   @id @default(uuid())
  moduleId    String   @unique                // one workbook per module
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  tenantId    String
  title       String   @default("")
  sections    String   @default("[]")          // JSON: array of section objects
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions WorkbookSubmission[]
}

model WorkbookSubmission {
  id          String    @id @default(uuid())
  workbookId  String
  workbook    Workbook  @relation(fields: [workbookId], references: [id], onDelete: Cascade)
  userId      String
  tenantId    String
  answers     String    @default("{}")          // JSON: { fieldId: value }
  status      String    @default("draft")       // draft | submitted | reviewed | returned
  feedback    String    @default("")            // facilitator feedback
  score       String    @default("")            // e.g. "22/28"
  submittedAt DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workbookId, userId])
}

model TrainingSession {
  id          String   @id @default(uuid())
  tenantId    String
  courseId    String?                         // optional: link to a course
  title       String
  description String   @default("")
  date        DateTime
  startTime   String   @default("")
  endTime     String   @default("")
  location    String   @default("")
  notes       String   @default("")           // admin notes
  capacity    Int      @default(20)
  status      String   @default("scheduled")  // scheduled | completed | cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendees   SessionAttendee[]
}

model SessionAttendee {
  id           String          @id @default(uuid())
  sessionId    String
  session      TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId       String
  tenantId     String
  status       String          @default("scheduled") // scheduled | confirmed | attended | absent | excused
  notifiedAt   DateTime?                              // when they were first notified
  reminderSent Boolean         @default(false)        // 24h reminder sent?
  createdAt    DateTime        @default(now())

  @@unique([sessionId, userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  title     String
  message   String
  type      String   @default("info")    // info | reminder | schedule | result
  read      Boolean  @default(false)
  linkUrl   String   @default("")        // optional deep link
  createdAt DateTime @default(now())
}
